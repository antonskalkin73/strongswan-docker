# ipsec.secrets.example – placeholder secrets file
#
# Copy this file to config/ipsec.secrets on the VPS and fill in real values.
# NEVER commit config/ipsec.secrets to version control.
#
# Format reference: https://wiki.strongswan.org/projects/strongswan/wiki/IpsecSecrets

# Server private key – path is relative to /etc/ipsec.d/private/ inside the container.
# The actual file (server-key.pem) must be placed in ./certs/private/ on the host.
: RSA server-key.pem

# EAP credentials for roadwarrior clients (username/password).
# Add one line per user:
#   VPN_USERNAME : EAP "VPN_PASSWORD"
alice : EAP "changeme-use-a-strong-password"
